<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_main"
    android:paddingHorizontal="28dp"
    android:paddingTop="48dp"
    android:paddingBottom="32dp">

    <!-- Título -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:text="Recabo de información previa"
        android:textColor="@color/text_black"
        android:textSize="22sp"
        android:textStyle="bold"
        android:gravity="center"
        android:lineSpacingExtra="4dp" />

    <!-- Descripción -->
    <TextView
        android:id="@+id/tvDescription"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="El conocimiento del huerto nos ayuda a brindarte una mejor experiencia de usuario, selecciona el tipo de huerto al cuál atiendes."
        android:textColor="@color/text_gray"
        android:textSize="13sp"
        android:gravity="center"
        android:lineSpacingExtra="3dp" />

    <!-- Espacio entre descripción y opciones -->
    <Space
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- Opción Invernadero -->
    <LinearLayout
        android:id="@+id/llInvernadero"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:layout_marginBottom="14dp"
        android:background="@drawable/bg_option_rounded"
        android:elevation="2dp">

        <RadioButton
            android:id="@+id/rbInvernadero"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:buttonTint="@color/green_primary" />

        <ImageView
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="8dp"
            android:src="@drawable/greenhouse_icon2"
            android:scaleType="fitCenter"
            android:contentDescription="Invernadero" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:text="Invernadero (de cualquier estilo)"
            android:textColor="@color/text_white"
            android:textSize="14sp" />

    </LinearLayout>

    <!-- Opción Jardín doméstico -->
    <LinearLayout
        android:id="@+id/llJardin"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:layout_marginBottom="14dp"
        android:background="@drawable/bg_option_rounded"
        android:elevation="2dp">

        <RadioButton
            android:id="@+id/rbJardin"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:buttonTint="@color/green_primary" />

        <ImageView
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="8dp"
            android:src="@drawable/nuevousuario"
            android:scaleType="fitCenter"
            android:contentDescription="Jardín doméstico" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:text="Jardín doméstico"
            android:textColor="@color/text_white"
            android:textSize="14sp" />

    </LinearLayout>

    <!-- Opción Huerto urbano -->
    <LinearLayout
        android:id="@+id/llUrbano"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:background="@drawable/bg_option_rounded"
        android:elevation="2dp">

        <RadioButton
            android:id="@+id/rbUrbano"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:buttonTint="@color/green_primary" />

        <ImageView
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="8dp"
            android:src="@drawable/sensores"
            android:scaleType="fitCenter"
            android:contentDescription="Huerto urbano" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:text="Huerto urbano"
            android:textColor="@color/text_white"
            android:textSize="14sp" />

    </LinearLayout>

    <!-- Espacio entre opciones y botón -->
    <Space
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- Botón CONTINUAR con gradiente -->
    <Button
        android:id="@+id/btnContinuar"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="CONTINUAR"
        android:textColor="@color/white"
        android:textSize="15sp"
        android:textStyle="bold"
        android:background="@drawable/btn_gradient"
        android:enabled="false"
        android:alpha="0.5"
        android:stateListAnimator="@null" />

</LinearLayout>